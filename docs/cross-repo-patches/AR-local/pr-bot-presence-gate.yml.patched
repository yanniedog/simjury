name: pr-bot-presence-gate

# Single-shot bot presence check. Re-fires on PR lifecycle + bot review/comment events,
# so a miss while bots are still in flight self-heals when they post (no GraphQL polling from
# Actions â€” installation quota). Local --watch (npm run wait-for-bots) remains the pre-merge gate.
on:
  pull_request:
    types: [opened, synchronize, reopened, ready_for_review]
  pull_request_review:
    types: [submitted]
  issue_comment:
    types: [created]
  workflow_dispatch:
    inputs:
      pr_number:
        description: Pull request number
        required: true
        type: string

permissions:
  contents: read
  pull-requests: read
  issues: read

concurrency:
  # cancel-in-progress MUST stay false for a required check. Cancelling an
  # in-flight run leaves a "cancelled" check-run that branch protection reads as
  # the latest required status, blocking the PR even when a later run succeeds
  # (the "BLOCKED but all-green" trap that forced empty re-trigger commits on
  # every PR). With false, the newest event still runs to completion, so the
  # latest required check-run is always success/failure â€” never a stale cancel.
  group: bot-presence-gate-${{ github.event.pull_request.number || github.event.issue.number || inputs.pr_number || github.run_id }}
  cancel-in-progress: false

jobs:
  bot-presence-gate:
    # Re-evaluate on bot reviews/comments so a single-shot miss self-heals.
    # issue_comment fires for both issues and PRs - gate on PR-only.
    if: >-
      github.event.pull_request != null
      || github.event.review != null
      || (github.event_name == 'issue_comment' && github.event.issue.pull_request != null)
      || github.event_name == 'workflow_dispatch'
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: "24"
      - name: Skip bot wait for non-human / chore PRs
        id: gate_exempt
        env:
          GH_TOKEN: ${{ secrets.BOT_GATE_TOKEN || github.token }}
          PR_TITLE: ${{ github.event.pull_request.title }}
          PR_AUTHOR: ${{ github.event.pull_request.user.login }}
          PR_AUTHOR_TYPE: ${{ github.event.pull_request.user.type }}
        run: |
          case "${{ github.event_name }}" in
            workflow_dispatch) PR="${{ inputs.pr_number }}" ;;
            issue_comment)     PR="${{ github.event.issue.number }}" ;;
            pull_request_review) PR="${{ github.event.pull_request.number }}" ;;
            *)                 PR="${{ github.event.pull_request.number }}" ;;
          esac
          export PR
          EXEMPT=$(node scripts/pr-gate-exempt-reason.mjs || true)
          if [ -n "$EXEMPT" ]; then
            echo "gate_exempt=true" >> "$GITHUB_OUTPUT"
            echo "gate_exempt_reason=$EXEMPT" >> "$GITHUB_OUTPUT"
            echo "PR #$PR is gate-exempt ($EXEMPT) — bot review not required"
          else
            echo "gate_exempt=false" >> "$GITHUB_OUTPUT"
          fi
      - name: Gate exempt — pass (no bot wait)
        if: steps.gate_exempt.outputs.gate_exempt == 'true'
        run: |
          echo "bot-presence-gate: skipped (${{ steps.gate_exempt.outputs.gate_exempt_reason }} — human bot review not required)"
      - name: Required bot wait gate (single shot)
        if: steps.gate_exempt.outputs.gate_exempt != 'true'
        env:
          GH_TOKEN: ${{ secrets.BOT_GATE_TOKEN || github.token }}
          GITHUB_REPOSITORY: ${{ github.repository }}
          AR_BOT_WAIT_REQUIRED: gemini,codex,sourcery
          BOT_WAIT_IGNORE_CHECK_NAMES: bot-presence-gate,bot-feedback-gate,pr-bot-presence-gate,pr-bot-feedback-check
          # CI has no .ar-bot-wait state; anchor falls back to PR createdAt (long-open PRs exceed 28m).
          BOT_WAIT_MAX_MIN: "240"
        run: |
          case "${{ github.event_name }}" in
            workflow_dispatch) PR="${{ inputs.pr_number }}" ;;
            issue_comment)     PR="${{ github.event.issue.number }}" ;;
            pull_request_review) PR="${{ github.event.pull_request.number }}" ;;
            *)                 PR="${{ github.event.pull_request.number }}" ;;
          esac
          set +e
          npm run wait-for-bots -- --pr "$PR"
          code=$?
          set -e
          if [ "$code" -eq 2 ]; then
            echo "::warning::Bot wait not ready yet (exit 2) â€” run npm run wait-for-bots locally until exit 0, then re-run this workflow"
            exit 1
          fi
          exit "$code"
